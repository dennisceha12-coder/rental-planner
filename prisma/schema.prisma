generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  CONCEPT
  OFFERTE
  BEVESTIGD
  AFGEROND
}

enum CrewPhase {
  OPBOUW
  SHOW
  AFBOUW
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

enum TransportType {
  PER_KM
  FIXED
}

model CompanySettings {
  id                String @id @default("default")
  companyName       String @default("")
  address           String @default("")
  email             String?
  phone             String?
  kvkNumber         String?
  vatNumber         String?
  iban              String?
  quoteValidityDays Int    @default(30)
  defaultVatRate    Float  @default(21)
  paymentTerms      String?
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  vatNumber String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id           String        @id @default(cuid())
  title        String
  status       ProjectStatus @default(CONCEPT)
  quoteNumber  String?
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  location     String?
  loadIn       DateTime?
  showDate     DateTime?
  loadOut      DateTime?
  loadInTime   String?
  showTime     String?
  loadOutTime  String?
  siteContact  String?
  parkingNotes String?
  notes        String?
  hourlyRate           Float?
  transportType        TransportType @default(PER_KM)
  transportKm          Float?
  transportRatePerKm   Float?
  transportFixedAmount Float?
  discountType     DiscountType?
  discountValue    Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lines        ProjectLine[]
  crewShifts   CrewShift[]
}

model CrewShift {
  id         String           @id @default(cuid())
  projectId  String
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase      CrewPhase
  role       String?
  headcount  Int
  date       DateTime
  startTime  String
  endTime    String
  hourlyRate Float?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  staffAssignments CrewShiftStaff[]
}

model Staff {
  id        String           @id @default(cuid())
  name      String
  role      String?
  phone     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  crewAssignments CrewShiftStaff[]
}

model CrewShiftStaff {
  id      String    @id @default(cuid())
  shiftId String
  shift   CrewShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffId String
  staff   Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([shiftId, staffId])
}

model Equipment {
  id        String        @id @default(cuid())
  name      String
  category  String?
  dailyRate Float
  stockQty  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  lines     ProjectLine[]
}

model ProjectLine {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])
  customName       String?
  customDailyRate  Float?
  quantity    Int
  rentalStart DateTime
  rentalEnd   DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
